# mail-ai environment variables.
#
# Copy to .env (gitignored) and edit. `make dev` (and every other
# `make` target) auto-loads this file via `-include .env` + `export`,
# so all values below reach pnpm / turbo / tsx / vite without any
# extra shell incantation.
#
# Vite also auto-loads apps/web/.env.local if you prefer per-app
# overrides for browser-visible (VITE_*) values.

# ───────────────────────────────────────────────────────────────────────
# Dev stack ports
# ───────────────────────────────────────────────────────────────────────
# Match the values in Makefile / docker-compose; override only if these
# clash with another project running on your machine.
WEB_PORT=3200
API_PORT=8200
# Realtime WebSocket defaults to merged mode on API_PORT. Uncomment to
# opt into the legacy split WebSocket server; Vite will proxy /ws there.
# MAILAI_RT_PORT=1235

# ───────────────────────────────────────────────────────────────────────
# Postgres (overlay-db)
# ───────────────────────────────────────────────────────────────────────
# Defaults to the docker-compose dev DB on :5532. Production should
# point at a managed Postgres with TLS.
DATABASE_URL=postgres://mailai:mailai@localhost:5532/mailai

# ───────────────────────────────────────────────────────────────────────
# Web ↔ API wiring
# ───────────────────────────────────────────────────────────────────────
# Where the Vite dev server proxies /api/* to. Defaults to the local
# API at 127.0.0.1:8200; override when the API is on another host.
MAILAI_API_ORIGIN=http://127.0.0.1:8200
# Optional: set if the browser must hit the API directly (no dev
# proxy, e.g. when serving the web app from a CDN / static host).
# Leave blank in normal dev so requests stay relative and go through
# Vite's proxy.
# VITE_MAILAI_API_URL=

# ───────────────────────────────────────────────────────────────────────
# OAuth — Nango (initial handshake only)
# ───────────────────────────────────────────────────────────────────────
# Sign up at https://app.nango.dev and copy the secret key.
# Without NANGO_SECRET_KEY the API runs in "demo mode": the Connect
# dialog renders setup instructions instead of opening a popup.
NANGO_SECRET_KEY=
# Override only if you self-host Nango.
NANGO_HOST=https://api.nango.dev
# Integration IDs as configured in your Nango dashboard. Defaults match
# Nango's standard provider templates.
NANGO_GOOGLE_INTEGRATION=google-mail
NANGO_OUTLOOK_INTEGRATION=outlook

# ───────────────────────────────────────────────────────────────────────
# OAuth — provider client credentials (token refresh)
# ───────────────────────────────────────────────────────────────────────
# After Nango hands us the initial tokens, mail-ai refreshes directly
# against Google / Microsoft using these credentials. Required for any
# account that lives longer than the initial token's TTL (~1h).
#
# Demo-mode caveat: tokens issued under Nango's demo OAuth apps cannot
# be refreshed here because Nango doesn't expose its demo client_id /
# secret. Register your own apps for anything past one hour of testing.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
# 'common' = personal + work, 'consumers' = personal only,
# 'organizations' = AAD only, or a tenant GUID for single-tenant apps.
MICROSOFT_OAUTH_TENANT=common

# ───────────────────────────────────────────────────────────────────────
# Object storage (attachments, raw EMLs)
# ───────────────────────────────────────────────────────────────────────
# Defaults to the docker-compose dev MinIO on :9200 (`make stack-up` or
# `make stack-up-minio` alone when Postgres comes from hof-os native dev).
# Production should
# point at AWS S3 (omit S3_ENDPOINT, set S3_FORCE_PATH_STYLE=false) or
# any S3-compatible service. Names mirror collaboration-ai's so the
# future hof-os integration is a swap of these four values.
#
# Bucket is auto-created on server boot if missing (best-effort; in
# managed S3 you need s3:CreateBucket or pre-create it). Browser must
# be able to reach S3_ENDPOINT directly because presigned PUT/GET URLs
# include that host.
S3_ENDPOINT=http://localhost:9200
S3_REGION=us-east-1
S3_BUCKET=mailai-dev
S3_ACCESS_KEY=mailai
S3_SECRET_KEY=mailai-dev-secret
S3_FORCE_PATH_STYLE=true

# ───────────────────────────────────────────────────────────────────────
# Headless agent CLI / SDK (mail-agent)
# ───────────────────────────────────────────────────────────────────────
# Used by `mail-agent` and the HttpAgentClient when the --api-url flag
# isn't passed. Token is the bearer the API expects (when auth is on).
MAILAI_API_URL=http://127.0.0.1:8200
MAILAI_TOKEN=

# ───────────────────────────────────────────────────────────────────────
# Background sync (SyncScheduler)
# ───────────────────────────────────────────────────────────────────────
# Period at which a healthy account is re-synced. Failed accounts back
# off exponentially from this base (×2, ×4, … up to ×32). Defaults are
# 60s in dev, 300s for NODE_ENV=production.
# MAILAI_SYNC_INTERVAL_MS=60000
# Disable the in-process scheduler (handy when running the API in a
# debugger or against a recording proxy).
# MAILAI_SYNC_DISABLED=1

# ───────────────────────────────────────────────────────────────────────
# Push notifications (Phase 7)
# ───────────────────────────────────────────────────────────────────────
# When set, the SyncScheduler keeps every healthy account subscribed
# for push notifications and renews subscriptions before they expire.
# Either or both can be enabled independently — accounts of the
# matching provider opt in.
#
# Gmail subscriptions go through Cloud Pub/Sub. Set this to the
# fully-qualified topic name (`projects/<project>/topics/<topic>`).
# The Pub/Sub push subscription on that topic must POST to
# `<API_PUBLIC_URL>/api/webhooks/gmail`. See docs/push-setup.md.
# MAILAI_PUSH_GMAIL_TOPIC=projects/your-gcp-project/topics/mailai-gmail
#
# Microsoft Graph posts directly to a public HTTPS webhook. Set this
# to the externally reachable URL of `/api/webhooks/graph`. Graph
# requires HTTPS and a 200 response on the validation handshake.
# MAILAI_PUSH_GRAPH_WEBHOOK_URL=https://api.example.com/api/webhooks/graph

# ───────────────────────────────────────────────────────────────────────
# Tests (opt-in)
# ───────────────────────────────────────────────────────────────────────
# Enable Playwright e2e suites in apps/web/e2e/.
# MAILAI_E2E=1
# Override the URL Playwright hits.
# MAILAI_WEB_URL=http://127.0.0.1:3200

# Enable the Greenmail-backed integration suites in tests/integration/.
# Requires the dev compose stack to be running (Greenmail on 3025/3143).
# MAILAI_GREENMAIL=1
# MAILAI_IMAP_HOST=127.0.0.1
# MAILAI_IMAP_PORT=3143
# MAILAI_SMTP_PORT=3025

# Enable the 10k-message perf gate (long-running, opt-in).
# MAILAI_PERF=1
# MAILAI_PERF_N=10000
# MAILAI_PERF_INITIAL_MS=90000
# MAILAI_PERF_DELTA_MS=5000

# ───────────────────────────────────────────────────────────────────────
# Release tooling
# ───────────────────────────────────────────────────────────────────────
# Where scripts/release-tarballs.mjs writes the release artifacts.
# MAILAI_RELEASE_DIR=./release-out
