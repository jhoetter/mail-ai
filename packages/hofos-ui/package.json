{
  "name": "@mailai/hofos-ui",
  "version": "0.2.4",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "*.css",
    "dist/*.css"
  ],
  "scripts": {
    "build": "vite build && cp src/index.d.ts dist/index.d.ts",
    "build:dist": "pnpm run build",
    "typecheck": "echo \"types are generated from src/index.d.ts\"",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@nangohq/frontend": "^0.70.1",
    "dompurify": "^3.4.2",
    "lucide-react": "^0.574.0",
    "next-themes": "^0.4.6",
    "react-router": "^7.14.2"
  },
  "devDependencies": {
    "@mailai/agent": "workspace:*",
    "@mailai/core": "workspace:*",
    "@mailai/ui": "workspace:*",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  },
  "license": "MIT"
}
