{
  "name": "@mailai/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx --watch src/server.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mailai/agent": "workspace:*",
    "@mailai/collaboration": "workspace:*",
    "@mailai/core": "workspace:*",
    "@mailai/mime": "workspace:*",
    "@mailai/oauth-tokens": "workspace:*",
    "@mailai/overlay-db": "workspace:*",
    "@mailai/providers": "workspace:*",
    "fastify": "^5.1.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
