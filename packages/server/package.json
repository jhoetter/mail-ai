{
  "name": "@mailai/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx --watch src/server.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@mailai/agent": "workspace:*",
    "@mailai/collaboration": "workspace:*",
    "@mailai/core": "workspace:*",
    "@mailai/ics-parser": "workspace:*",
    "@mailai/mime": "workspace:*",
    "@mailai/oauth-tokens": "workspace:*",
    "@mailai/overlay-db": "workspace:*",
    "@mailai/providers": "workspace:*",
    "fastify": "^5.8.5",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
